---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404" fullPage>
  <div class="w-full max-w-sm px-4 text-center">
    <div class="w-24 h-24 rounded-3xl bg-primary/10 dark:bg-primary/20 flex items-center justify-center mx-auto mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>
    <p class="text-6xl font-black text-primary mb-2">404</p>
    <h1 class="text-xl font-bold mb-2">Page not found</h1>
    <p class="text-slate-500 dark:text-slate-400 text-sm mb-8">
      This page doesn't exist or was moved.
    </p>
    <a href="/storage" class="btn-primary inline-block">Back to Storage</a>
  </div>
</Layout>
