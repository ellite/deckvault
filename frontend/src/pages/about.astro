            </svg>
            <span>GitHub - ellite/deckvault</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 group-hover:opacity-40 transition-opacity ml-auto"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </a>
