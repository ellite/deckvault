---
import ThemeToggle from "./ThemeToggle.astro";

interface StorageMedium {
  id: number;
  type: string;
  label: string;
  color: string;
  games: unknown[];
}

interface Props {
  storageList: StorageMedium[];
  activeId?: number;
  username: string;
}
const { storageList, activeId, username } = Astro.props;
---

<!-- Mobile overlay -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-20 hidden lg:hidden" aria-hidden="true"></div>

<!-- Sidebar -->
<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 z-30 w-72 bg-white dark:bg-surface-dark border-r border-border dark:border-border-dark
         flex flex-col transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-5 h-16 border-b border-border dark:border-border-dark">
    <a href="/storage" class="flex items-center gap-2.5">
      <img src="/logo.svg" alt="DeckVault" class="w-8 h-8" />
      <span class="font-bold text-lg tracking-tight">DeckVault</span>
    </a>
    <ThemeToggle />
  </div>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto p-4 space-y-1">
    <!-- Storage mediums -->
    <p class="label px-3 mt-2 mb-3">Storage</p>

    {storageList.map((s) => (
      <a
        href={`/storage?storage=${s.id}`}
        class={`sidebar-item${activeId === s.id ? " active" : ""}`}
      >
        <span
          class="w-2.5 h-2.5 rounded-full flex-shrink-0"
          style={`background:${s.color}`}
        ></span>
        <span class="flex-1 truncate">{s.label}</span>
        <span class="text-xs text-slate-400 dark:text-slate-500 flex-shrink-0">
          {s.games.length} {s.games.length === 1 ? "game" : "games"}
        </span>
      </a>
    ))}

    <button
      id="add-storage-btn"
      class="sidebar-item w-full text-primary dark:text-primary-light mt-1"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      Add Storage
    </button>

    <!-- Pages -->
    <p class="label px-3 mt-6 mb-3">Pages</p>
    <a href="/storage" class={`sidebar-item${!activeId && Astro.url.pathname === "/storage" ? " active" : ""}`}>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
        <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
      </svg>
      Dashboard
    </a>
    <a href="/settings" class={`sidebar-item${Astro.url.pathname === "/settings" ? " active" : ""}`}>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 0 0-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 0 0-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 0 0-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 0 0-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 0 0 1.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      Settings
    </a>
  </nav>

  <!-- User footer -->
  <div class="p-4 border-t border-border dark:border-border-dark">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2.5">
        <div class="w-8 h-8 rounded-full bg-primary/20 dark:bg-primary/30 flex items-center justify-center">
          <span class="text-sm font-bold text-primary dark:text-primary-light">
            {username[0].toUpperCase()}
          </span>
        </div>
        <span class="text-sm font-medium truncate max-w-[120px]">{username}</span>
      </div>
      <form method="POST" action="/api/auth/logout">
        <button type="submit" class="btn-ghost p-1.5 text-xs" title="Logout">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
</aside>

<script>
  // Mobile sidebar toggle
  const sidebar = document.getElementById("sidebar");
  const overlay = document.getElementById("sidebar-overlay");
  const menuBtn = document.getElementById("mobile-menu-btn");

  function openSidebar() {
    sidebar?.classList.remove("-translate-x-full");
    overlay?.classList.remove("hidden");
  }
  function closeSidebar() {
    sidebar?.classList.add("-translate-x-full");
    overlay?.classList.add("hidden");
  }

  menuBtn?.addEventListener("click", openSidebar);
  overlay?.addEventListener("click", closeSidebar);

  // Expose for use by other scripts
  (window as any).openSidebar = openSidebar;
</script>
