---
interface Props {
  user?: { username: string; is_admin: boolean } | null;
  activePage?: "dashboard" | "library" | "settings" | "about";
}
const { user, activePage } = Astro.props;
---

<!-- Desktop top nav -->
<header class="hidden md:flex fixed top-0 inset-x-0 z-30 h-14 items-center gap-2 px-6
               bg-white/90 dark:bg-surface-dark/90 backdrop-blur-md
               border-b border-border dark:border-border-dark">
  <a href="/storage" class="flex items-center gap-2.5 mr-4 flex-shrink-0">
    <img src="/logo.svg" alt="" class="w-7 h-7" />
    <span class="font-bold text-base tracking-tight">DeckVault</span>
  </a>

  <nav class="flex items-center gap-1 flex-1">
    <a href="/storage"
       class={`px-3.5 py-1.5 rounded-lg text-sm font-medium transition-colors ${
         activePage === "dashboard"
           ? "bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light"
           : "text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-white/8"
       }`}>
      Storage
    </a>
    <a href="/library"
       class={`px-3.5 py-1.5 rounded-lg text-sm font-medium transition-colors ${
         activePage === "library"
           ? "bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light"
           : "text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-white/8"
       }`}>
      Library
    </a>
    <a href="/settings"
       class={`px-3.5 py-1.5 rounded-lg text-sm font-medium transition-colors ${
         activePage === "settings"
           ? "bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light"
           : "text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-white/8"
       }`}>
      Settings
    </a>
    <a href="/about"
       class={`px-3.5 py-1.5 rounded-lg text-sm font-medium transition-colors ${
         activePage === "about"
           ? "bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary-light"
           : "text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-white/8"
       }`}>
      About
    </a>
  </nav>

  <div class="flex items-center gap-2 flex-shrink-0">
    <button id="theme-toggle-nav" class="btn-ghost p-2 rounded-xl" aria-label="Toggle theme">
      <svg id="nav-sun" class="hidden dark:block w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="4"/><path stroke-linecap="round" d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
      </svg>
      <svg id="nav-moon" class="block dark:hidden w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>

    {user && (
      <div class="flex items-center gap-2 pl-2 border-l border-border dark:border-border-dark ml-1">
        <div class="w-7 h-7 rounded-full bg-primary/20 flex items-center justify-center flex-shrink-0">
          <span class="text-xs font-bold text-primary dark:text-primary-light">{user.username[0].toUpperCase()}</span>
        </div>
        <span class="text-sm font-medium text-slate-700 dark:text-slate-200 max-w-[120px] truncate">{user.username}</span>
        <button id="logout-btn-nav" class="btn-ghost p-1.5" title="Sign out" aria-label="Sign out">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
        </button>
      </div>
    )}
  </div>
</header>

<!-- Mobile top bar -->
<header class="md:hidden flex fixed top-0 inset-x-0 z-30 h-14 items-center gap-3 px-4
               bg-white/90 dark:bg-surface-dark/90 backdrop-blur-md
               border-b border-border dark:border-border-dark">
  <a href="/storage" class="flex items-center gap-2">
    <img src="/logo.svg" alt="" class="w-6 h-6" />
    <span class="font-bold tracking-tight">DeckVault</span>
  </a>
  <div class="flex-1"></div>
  <button id="theme-toggle-nav-m" class="btn-ghost p-2 rounded-xl" aria-label="Toggle theme">
    <svg class="hidden dark:block w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="4"/><path stroke-linecap="round" d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
    </svg>
    <svg class="block dark:hidden w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
  {user && (
    <button id="logout-btn-nav-m" class="btn-ghost p-1.5" title="Sign out" aria-label="Sign out">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
    </button>
  )}
</header>

<!-- Mobile bottom nav -->
<nav class="md:hidden fixed bottom-0 inset-x-0 z-30 h-16 flex items-center justify-around
            bg-white/95 dark:bg-surface-dark/95 backdrop-blur-md
            border-t border-border dark:border-border-dark">
  <a href="/storage"
     class={`flex flex-col items-center gap-0.5 px-5 py-2 rounded-xl transition-colors ${
       activePage === "dashboard"
         ? "text-primary dark:text-primary-light"
         : "text-slate-400 dark:text-slate-500"
     }`}>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={activePage === "dashboard" ? "2.5" : "1.5"}>
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
    </svg>
    <span class="text-[10px] font-medium">Storage</span>
  </a>
  <a href="/library"
     class={`flex flex-col items-center gap-0.5 px-5 py-2 rounded-xl transition-colors ${
       activePage === "library"
         ? "text-primary dark:text-primary-light"
         : "text-slate-400 dark:text-slate-500"
     }`}>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={activePage === "library" ? "2.5" : "1.5"}>
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
    </svg>
    <span class="text-[10px] font-medium">Library</span>
  </a>
  <a href="/settings"
     class={`flex flex-col items-center gap-0.5 px-4 py-2 rounded-xl transition-colors ${
       activePage === "settings"
         ? "text-primary dark:text-primary-light"
         : "text-slate-400 dark:text-slate-500"
     }`}>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={activePage === "settings" ? "2.5" : "1.5"}>
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><circle cx="12" cy="12" r="3"/>
    </svg>
    <span class="text-[10px] font-medium">Settings</span>
  </a>
  <a href="/about"
     class={`flex flex-col items-center gap-0.5 px-4 py-2 rounded-xl transition-colors ${
       activePage === "about"
         ? "text-primary dark:text-primary-light"
         : "text-slate-400 dark:text-slate-500"
     }`}>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={activePage === "about" ? "2.5" : "1.5"}>
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="8"/>
      <line x1="12" y1="12" x2="12" y2="16"/>
    </svg>
    <span class="text-[10px] font-medium">About</span>
  </a>
</nav>

<script>
  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("dv-theme", isDark ? "dark" : "light");
  }
  document.getElementById("theme-toggle-nav")?.addEventListener("click", toggleTheme);
  document.getElementById("theme-toggle-nav-m")?.addEventListener("click", toggleTheme);

  async function logout() {
    await fetch("/api/auth/logout", { method: "POST" });
    window.location.href = "/login";
  }
  document.getElementById("logout-btn-nav")?.addEventListener("click", logout);
  document.getElementById("logout-btn-nav-m")?.addEventListener("click", logout);
</script>
